APP_ENV=development
APP_URL=http://localhost/imperio-do-choco-main

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=imperio_do_choco
DB_USER=root
DB_PASS=

# Recuperacao de senha por email
# Use "log" em desenvolvimento, "brevo" para API da Brevo ou "smtp" para Gmail/Brevo/SendGrid SMTP.
EMAIL_PROVIDER=log
EMAIL_FROM=contato@velledulcis.com
EMAIL_FROM_NAME="Velle Dulcis"

